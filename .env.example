DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=add_your_password_here
DB_NAME=tech_pay_scale_db

# JWT signing (identity + vote + BFF must match)
SECRET_KEY=change-me-use-openssl-rand-hex-32

# BFF upstream URLs (local dev defaults)
IDENTITY_SERVICE_URL=http://localhost:8001
SALARY_SERVICE_URL=http://localhost:8002
VOTE_SERVICE_URL=http://localhost:8003
SEARCH_SERVICE_URL=http://localhost:8004
STATS_SERVICE_URL=http://localhost:8005

# Comma-separated origins for CORS, or * for any
CORS_ORIGINS=*